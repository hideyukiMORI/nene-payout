APP_ENV=local
APP_DEBUG=false
APP_NAME="NeNe Payout"
NENE2_MACHINE_API_KEY=
# Set to a random string (>=32 chars) to enable Bearer (JWT HS256) auth locally.
NENE2_LOCAL_JWT_SECRET=
PROBLEM_DETAILS_BASE_URL=https://nene-payout.dev/problems/

# --- Multi-tenancy (ADR 0018 / docs/explanation/multi-tenancy.md) ---
# single (Tier A / dev, one org owns the instance) | subdomain | path | custom_domain
TENANT_RESOLUTION=single
ORG_SLUG=payout
# BASE_DOMAIN=pay.example.com   # required for TENANT_RESOLUTION=subdomain

# --- Database (host / PHPUnit default: SQLite) ---
DATABASE_URL=
DB_ENV=local
DB_ADAPTER=sqlite
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=var/nene_payout.sqlite
DB_USER=nene_payout
DB_PASSWORD=
DB_CHARSET=utf8mb4

# --- Docker Compose overrides (copy to .env and uncomment for the local stack) ---
# DB_ADAPTER=mysql
# DB_HOST=mysql
# DB_PORT=3306
# DB_NAME=nene_payout
# DB_USER=nene_payout
# DB_PASSWORD=nene_payout
# MYSQL_ROOT_PASSWORD=nene_payout_root
#
# --- Local Docker ports — 90 lane (fixed/unique; docs/development/local-ports.md) ---
# NENE_PAYOUT_PORT=9000            # PHP API (HTTP)
# NENE_PAYOUT_PHPMYADMIN_PORT=9001 # phpMyAdmin
# NENE_PAYOUT_MYSQL_PORT=3400      # MySQL
# NENE_PAYOUT_FRONTEND_PORT=5190   # Vite dev server (run on host via npm)
