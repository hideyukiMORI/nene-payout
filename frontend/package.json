{
  "name": "nene-payout-frontend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22 <25",
    "npm": ">=10 <12"
  },
  "packageManager": "npm@10.9.7",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build && npm run build:widget",
    "build:widget": "vite build --config vite.widget.config.ts",
    "type-check": "tsc --noEmit",
    "lint": "eslint . --max-warnings 0",
    "format": "prettier --check .",
    "format:fix": "prettier --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "coverage:check": "vitest run --coverage && node tools/coverage-ratchet.mjs",
    "knip": "knip",
    "stylelint": "stylelint \"src/**/*.css\"",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "check": "npm run type-check && npm run lint && npm run format && npm run coverage:check && npm run knip && npm run stylelint"
  },
  "dependencies": {
    "@hideyukimori/nene2-client": "^1.1.0",
    "@hookform/resolvers": "^5.4.0",
    "@tanstack/react-query": "^5.101.2",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-hook-form": "^7.79.0",
    "react-router-dom": "^7.9.0",
    "zod": "^4.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@hideyukimori/nene2-standards": "^1.1.0",
    "@hideyukimori/nene2-tokens": "1.1.0",
    "@storybook/react-vite": "^10.5.2",
    "@tailwindcss/vite": "^4.1.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^22.10.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.0",
    "eslint-import-resolver-typescript": "^4.4.0",
    "eslint-plugin-import-x": "^4.17.1",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react-hooks": "^7.1.0",
    "eslint-plugin-react-refresh": "^0.5.0",
    "globals": "^17.7.0",
    "jsdom": "^29.1.1",
    "knip": "^6.16.1",
    "msw": "^2.12.0",
    "prettier": "^3.9.5",
    "storybook": "^10.5.2",
    "stylelint": "^16.26.1",
    "tailwindcss": "^4.1.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.64.0",
    "vite": "^8.0.16",
    "vitest": "^4.1.9"
  },
  "overrides": {
    "eslint-plugin-jsx-a11y": {
      "eslint": "$eslint"
    }
  }
}
